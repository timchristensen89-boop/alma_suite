generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  RESOLVED
  CLOSED
}

enum ChecklistRunStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
}

enum ChecklistItemResult {
  PENDING
  PASS
  FAIL
  NA
}

enum StaffRecordType {
  RSA
  RSG
  FSS
  FIRST_AID
  FOOD_SAFETY
  ALLERGEN
  TRAINING
  OTHER
}

enum StaffRecordStatus {
  PENDING
  APPROVED
  EXPIRED
}

enum IncidentStatus {
  OPEN
  UNDER_REVIEW
  CLOSED
}

enum TemperatureAssetStatus {
  ACTIVE
  INACTIVE
}

enum TemperatureLogSource {
  MANUAL
  GOVEE
}

enum TemperatureLogStatus {
  IN_RANGE
  OUT_OF_RANGE
}

enum LiquorLicenceType {
  HOTEL
  ON_PREMISES
  SMALL_BAR
  CLUB
  PACKAGED
  PRODUCER_WHOLESALER
  LIMITED
  OUTDOOR_SEATING
  FOOD_BUSINESS
  FOOTPATH_DINING
  MUSIC_ENTERTAINMENT
  SIGNAGE
  FIRE_SAFETY
  WASTE_TRADE
  OTHER
}

enum LiquorLicenceStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  PENDING
}

enum StockItemStatus {
  ACTIVE
  ARCHIVED
}

enum SupplierStatus {
  ACTIVE
  ARCHIVED
}

enum StocktakeStatus {
  IN_PROGRESS
  SUBMITTED
}

enum InventoryMovementType {
  STOCKTAKE_ADJUSTMENT
  STOCKTAKE_CORRECTION
  STOCKTAKE_REVERSAL
}

enum AlmaAppId {
  COMPLIANCE
  STOCK
  STAFF
  REPORTS
  RESERVE
  MARKETING
  GIFTCARDS
  TRAINING
  SETTINGS
}

enum StaffAppAccessStatus {
  ENABLED
  DISABLED
  PENDING
}

enum RosterShiftStatus {
  DRAFT
  PUBLISHED
  COMPLETED
  CANCELLED
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  EXPORTED
}

enum TrainingModuleStatus {
  ACTIVE
  ARCHIVED
}

enum StaffTrainingStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

enum ReserveReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ReserveServicePeriod {
  BREAKFAST
  LUNCH
  DINNER
  EVENT
}

enum MarketingChannel {
  EMAIL
  SMS
}

enum MarketingCampaignStatus {
  DRAFT
  READY
  SENT
  ARCHIVED
}

enum GiftCardStatus {
  PENDING_PAYMENT
  ACTIVE
  REDEEMED
  CANCELLED
  EXPIRED
}

enum GiftCardRedemptionStatus {
  COMPLETED
  VOIDED
}

enum GiftCardPromoDiscountType {
  PERCENT
  FIXED_AMOUNT
}

enum SuiteChatChannelType {
  GENERAL
  VENUE
  AREA
  GROUP
  DIRECT
}

model Issue {
  id              String           @id @default(cuid())
  legacyId        String?          @unique
  title           String
  description     String
  severity        IssueSeverity
  category        String
  status          IssueStatus      @default(OPEN)
  assignee        String?
  dueDate         DateTime?
  notes           String?
  resolutionNotes String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  evidence        IssueEvidence[]
  activities      IssueActivity[]
  checklistLinks  ChecklistItem[]
  auditLinks      AuditFinding[]
  incidentLinks   IncidentReport[]
}

model IssueEvidence {
  id        String   @id @default(cuid())
  legacyId  String?  @unique
  issueId   String
  name      String
  url       String
  fileType  String?
  createdAt DateTime @default(now())
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
}

model IssueActivity {
  id        String   @id @default(cuid())
  legacyId  String?  @unique
  issueId   String
  action    String
  message   String
  actor     String
  createdAt DateTime @default(now())
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
}

model ChecklistTemplate {
  id        String                  @id @default(cuid())
  legacyId  String?                 @unique
  name      String
  area      String?
  items     ChecklistItemTemplate[]
  runs      ChecklistRun[]
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
}

model ChecklistItemTemplate {
  id          String            @id @default(cuid())
  legacyId    String?           @unique
  templateId  String
  label       String
  description String?
  position    Int
  template    ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ChecklistRun {
  id          String             @id @default(cuid())
  legacyId    String?            @unique
  templateId  String
  runDate     DateTime           @default(now())
  status      ChecklistRunStatus @default(OPEN)
  area        String?
  performedBy String?
  notes       String?
  template    ChecklistTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items       ChecklistItem[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model ChecklistItem {
  id             String              @id @default(cuid())
  legacyId       String?             @unique
  runId          String
  templateItemId String?
  label          String
  description    String?
  position       Int
  result         ChecklistItemResult @default(PENDING)
  notes          String?
  linkedIssueId  String?
  run            ChecklistRun        @relation(fields: [runId], references: [id], onDelete: Cascade)
  linkedIssue    Issue?              @relation(fields: [linkedIssueId], references: [id])
}

model AuditTemplate {
  id        String                 @id @default(cuid())
  legacyId  String?                @unique
  name      String
  sections  AuditTemplateSection[]
  runs      AuditRun[]
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
}

model AuditTemplateSection {
  id          String        @id @default(cuid())
  legacyId    String?       @unique
  templateId  String
  title       String
  description String?
  position    Int
  template    AuditTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model AuditRun {
  id         String         @id @default(cuid())
  legacyId   String?        @unique
  templateId String
  title      String
  score      Float?
  summary    String?
  runDate    DateTime       @default(now())
  template   AuditTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  findings   AuditFinding[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model AuditFinding {
  id            String   @id @default(cuid())
  legacyId      String?  @unique
  auditRunId    String
  sectionTitle  String
  finding       String
  score         Float?
  linkedIssueId String?
  auditRun      AuditRun @relation(fields: [auditRunId], references: [id], onDelete: Cascade)
  linkedIssue   Issue?   @relation(fields: [linkedIssueId], references: [id])
}

model StaffProfile {
  id               String                  @id @default(cuid())
  firstName        String
  lastName         String
  roleTitle        String
  email            String?                 @unique
  phone            String?
  venue            String?
  employmentStatus String                  @default("ACTIVE")
  startDate        DateTime?
  dateOfBirth      DateTime?
  addressLine1     String?
  addressLine2     String?
  suburb           String?
  state            String?
  postcode         String?
  emergencyContactName         String?
  emergencyContactRelationship String?
  emergencyContactPhone        String?
  employmentType   String?
  payType          String?
  payRateCents     Int?
  payAward         String?
  taxFileNumber    String?
  taxResidencyStatus String?
  taxFreeThreshold Boolean?
  hasStudyTrainingLoan Boolean?
  superFundName    String?
  superFundAbn     String?
  superFundUsi     String?
  superMemberNumber String?
  bankAccountName  String?
  bankBsb          String?
  bankAccountNumber String?
  visaStatus       String?
  visaSubclass     String?
  visaExpiryDate   DateTime?
  workRightsNotes  String?
  xeroEmployeeId   String?
  xeroPayrollCalendarId String?
  xeroEarningsRateId String?
  trainingLevel    Int                     @default(0)
  trainingPayRateCents Int?
  notes            String?
  mergedIntoStaffProfileId String?
  mergedAt         DateTime?
  mergedByUserId   String?
  passwordHash     String?
  isAdmin          Boolean                 @default(false)
  lastLoginAt      DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  records          StaffComplianceRecord[]
  managerNotes     StaffManagerNote[]
  payProfile       StaffPayProfile?
  managementEvents StaffManagementEvent[]
  passwordResetTokens StaffPasswordResetToken[]
  appAccess        StaffAppAccess[]
  rosterShifts     RosterShift[]
  timesheets       Timesheet[]
  trainingRecords  StaffTrainingRecord[]
  tipPaymentRunLines StaffTipPaymentRunLine[]

  @@index([venue])
  @@index([mergedIntoStaffProfileId])
  @@index([xeroEmployeeId])
}

model StaffManagerNote {
  id             String       @id @default(cuid())
  staffProfileId String
  body           String
  createdById    String
  createdByName  String
  createdByEmail String?
  createdAt      DateTime     @default(now())
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@index([staffProfileId, createdAt])
  @@index([createdById])
}

model StaffPayProfile {
  id                            String       @id @default(cuid())
  staffProfileId                String       @unique
  awardCode                     String
  awardName                     String
  awardClassification           String
  employmentType                String
  payMode                       String       @default("AWARD")
  awardRateSource               String
  awardRateEffectiveFrom        DateTime
  payGuidePublishedAt           DateTime
  rateSetVersion                String
  ordinaryHourlyRateCents       Int
  casualLoadedHourlyRateCents   Int?
  manualFullTimePayAmountCents  Int?
  manualFullTimePayFrequency    String?
  manualFullTimePayNote         String?
  payUpdatedAt                  DateTime     @default(now())
  payUpdatedByUserId            String?
  createdAt                     DateTime     @default(now())
  updatedAt                     DateTime     @updatedAt
  staffProfile                  StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@index([awardCode, awardClassification])
  @@index([payUpdatedAt])
}

model StaffManagementEvent {
  id             String       @id @default(cuid())
  staffProfileId String
  eventType      String
  summary        String
  metadata       Json         @default("{}")
  createdById    String?
  createdByName  String?
  createdByEmail String?
  createdAt      DateTime     @default(now())
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@index([staffProfileId, createdAt])
  @@index([eventType, createdAt])
}

model StaffPasswordResetToken {
  id              String       @id @default(cuid())
  staffProfileId  String
  tokenHash       String       @unique
  requestedById   String?
  requestedByName String?
  requestedByEmail String?
  requestIp       String?
  userAgent       String?
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime     @default(now())
  staffProfile    StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@index([staffProfileId, createdAt])
  @@index([expiresAt])
}

model StaffAppAccess {
  id             String               @id @default(cuid())
  staffProfileId String
  appId          AlmaAppId
  status         StaffAppAccessStatus @default(DISABLED)
  role           String               @default("USER")
  permissions    Json                 @default("{}")
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  staffProfile   StaffProfile         @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@unique([staffProfileId, appId])
  @@index([appId, status])
}

model SuiteAnnouncement {
  id            String     @id @default(cuid())
  title         String
  body          String
  audience      String     @default("ALL")
  appId         AlmaAppId?
  venue         String?
  pinned        Boolean    @default(false)
  createdById   String?
  createdByName String?
  updatedById   String?
  updatedByName String?
  deletedAt     DateTime?
  deletedById   String?
  deletedByName String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  expiresAt     DateTime?

  @@index([audience, appId, venue, createdAt])
  @@index([expiresAt])
  @@index([deletedAt])
}

model SuiteChatChannel {
  id                String               @id @default(cuid())
  name              String
  description       String?
  channelKey        String               @unique
  type              SuiteChatChannelType @default(GROUP)
  appId             AlmaAppId?
  venue             String?
  groupKey          String?
  isActive          Boolean              @default(true)
  readPermission    String?
  postPermission    String?
  directMessagesAllowed Boolean          @default(false)
  createdById       String?
  createdByName     String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  messages          SuiteChatMessage[]

  @@index([type, appId, venue, isActive])
  @@index([groupKey])
}

model SuiteChatMessage {
  id            String     @id @default(cuid())
  channelId     String?
  channel       String     @default("general")
  channelType   SuiteChatChannelType @default(GENERAL)
  appId         AlmaAppId?
  venue         String?
  recipientId   String?
  recipientName String?
  body          String
  createdById   String?
  createdByName String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  editedAt      DateTime?
  deletedAt     DateTime?
  deletedById   String?
  deletedByName String?
  channelRef    SuiteChatChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([channel, appId, venue, createdAt])
  @@index([channelId, createdAt])
  @@index([createdById, createdAt])
  @@index([recipientId, createdAt])
  @@index([deletedAt])
}

model TrainingModule {
  id               String               @id @default(cuid())
  title            String
  description      String?
  category         String?
  level            Int                  @default(1)
  estimatedMinutes Int?
  status           TrainingModuleStatus @default(ACTIVE)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  records          StaffTrainingRecord[]

  @@index([status, level])
  @@index([category])
}

model TrainingLevelPayRule {
  id           String   @id @default(cuid())
  level        Int      @unique
  label        String
  payRateCents Int
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model StaffTrainingRecord {
  id             String              @id @default(cuid())
  staffProfileId String
  moduleId       String
  status         StaffTrainingStatus @default(ASSIGNED)
  assignedAt     DateTime            @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  expiresAt      DateTime?
  score          Float?
  evidenceName   String?
  evidenceUrl    String?
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  staffProfile   StaffProfile        @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  module         TrainingModule      @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([staffProfileId, moduleId])
  @@index([staffProfileId, status])
  @@index([moduleId, status])
}

model RosterShift {
  id             String            @id @default(cuid())
  staffProfileId String
  venue          String?
  area           String?
  roleTitle      String?
  startsAt       DateTime
  endsAt         DateTime
  breakMinutes   Int               @default(0)
  status         RosterShiftStatus @default(DRAFT)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  staffProfile   StaffProfile      @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@index([staffProfileId, startsAt])
  @@index([startsAt, endsAt])
}

model RosterForecastSnapshot {
  id                 String   @id @default(cuid())
  weekStart          DateTime
  weekEnd            DateTime
  venue              String?
  source             String?
  targetWagePercent  Float
  forecastSalesCents Int
  wageBudgetCents    Int
  rosterCostCents    Int
  plannedHours       Float
  recommendedHours   Float
  dailySalesCents    Json
  venueBreakdown     Json
  areaBreakdown      Json
  publishedById      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([weekStart, weekEnd, venue])
  @@index([weekStart, weekEnd])
  @@index([venue, weekStart])
}

model SalesActualEntry {
  id           String   @id @default(cuid())
  venue        String
  serviceDate  DateTime
  salesCents   Int
  source       String   @default("manual")
  externalId   String?
  notes        String?
  importedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([venue, serviceDate, source, externalId])
  @@index([serviceDate])
  @@index([venue, serviceDate])
}

model ReserveGuest {
  id             String                @id @default(cuid())
  firstName      String
  lastName       String
  email          String?
  phone          String?
  tags           String[]              @default([])
  allergyNotes   String?
  visitNotes     String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  reservations   ReserveReservation[]
  marketingContact MarketingContact?

  @@index([lastName, firstName])
  @@index([email])
  @@index([phone])
}

model ReserveTable {
  id             String                @id @default(cuid())
  venue          String
  area           String
  label          String
  minCovers      Int                   @default(1)
  maxCovers      Int
  sortOrder      Int                   @default(0)
  isActive       Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  reservations   ReserveReservation[]

  @@unique([venue, label])
  @@index([venue, area, sortOrder])
  @@index([isActive])
}

model ReserveReservation {
  id             String                   @id @default(cuid())
  venue          String
  serviceDate    DateTime
  servicePeriod  ReserveServicePeriod
  startsAt       DateTime
  endsAt         DateTime
  covers         Int
  status         ReserveReservationStatus @default(PENDING)
  source         String                   @default("manager")
  tableId        String?
  guestId        String
  occasion       String?
  notes          String?
  createdById    String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  guest          ReserveGuest             @relation(fields: [guestId], references: [id], onDelete: Cascade)
  table          ReserveTable?            @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@index([venue, serviceDate, servicePeriod])
  @@index([startsAt, endsAt])
  @@index([status, serviceDate])
  @@index([guestId])
  @@index([tableId])
}

model MarketingContact {
  id             String                       @id @default(cuid())
  firstName      String
  lastName       String
  email          String?
  phone          String?
  venue          String?
  source         String                       @default("manual")
  tags           String[]                     @default([])
  consentEmail   Boolean                      @default(false)
  consentSms     Boolean                      @default(false)
  totalVisits    Int                          @default(0)
  lastVisitAt    DateTime?
  allergyNotes   String?
  notes          String?
  reserveGuestId String?                      @unique
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  reserveGuest   ReserveGuest?                @relation(fields: [reserveGuestId], references: [id], onDelete: SetNull)
  recipients     MarketingCampaignRecipient[]

  @@index([lastName, firstName])
  @@index([email])
  @@index([phone])
  @@index([venue])
  @@index([source])
}

model MarketingSegment {
  id          String   @id @default(cuid())
  name        String
  description String?
  venue       String?
  rules       Json     @default("{}")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([venue])
  @@index([isActive])
}

model MarketingCampaign {
  id           String                       @id @default(cuid())
  name         String
  channel      MarketingChannel
  status       MarketingCampaignStatus      @default(DRAFT)
  audienceName String?
  subject      String?
  previewText  String?
  body         String
  scheduledFor DateTime?
  sentAt       DateTime?
  createdById  String?
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt
  recipients   MarketingCampaignRecipient[]

  @@index([status, channel])
  @@index([scheduledFor])
}

model MarketingCampaignRecipient {
  id         String            @id @default(cuid())
  campaignId String
  contactId  String
  status     String            @default("QUEUED")
  sentAt     DateTime?
  error      String?
  createdAt  DateTime          @default(now())
  campaign   MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact    MarketingContact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([contactId])
  @@index([status])
}

model GiftCard {
  id                      String                 @id @default(cuid())
  code                    String                 @unique
  status                  GiftCardStatus         @default(PENDING_PAYMENT)
  initialValueCents       Int
  balanceCents            Int
  discountCents           Int                    @default(0)
  amountPaidCents         Int?
  currency                String                 @default("aud")
  purchaserName           String
  purchaserEmail          String
  recipientName           String?
  recipientEmail          String?
  message                 String?
  promoCodeId             String?
  promoCodeSnapshot       String?
  testMode                Boolean                @default(false)
  stripeCheckoutSessionId String?                @unique
  stripePaymentIntentId   String?
  emailedAt               DateTime?
  emailError              String?
  cancelledAt             DateTime?
  cancelReason            String?
  refundNote              String?
  cancelledById           String?
  paidAt                  DateTime?
  expiresAt               DateTime?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  promoCode               GiftCardPromoCode?     @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  redemptions             GiftCardRedemption[]

  @@index([status])
  @@index([purchaserEmail])
  @@index([recipientEmail])
  @@index([createdAt])
  @@index([promoCodeId])
  @@index([testMode])
}

model GiftCardPromoCode {
  id             String                    @id @default(cuid())
  code           String                    @unique
  description    String?
  discountType   GiftCardPromoDiscountType
  percentOff     Int?
  amountOffCents Int?
  isActive       Boolean                   @default(true)
  startsAt       DateTime?
  expiresAt      DateTime?
  maxRedemptions Int?
  createdById    String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  giftCards      GiftCard[]

  @@index([isActive])
  @@index([expiresAt])
  @@index([createdAt])
}

model GiftCardRedemption {
  id             String                   @id @default(cuid())
  giftCardId     String
  amountCents    Int
  venue          String?
  notes          String?
  status         GiftCardRedemptionStatus @default(COMPLETED)
  redeemedById   String?
  redeemedAt     DateTime                 @default(now())
  createdAt      DateTime                 @default(now())
  giftCard       GiftCard                 @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  @@index([giftCardId])
  @@index([redeemedAt])
  @@index([venue])
}

model Timesheet {
  id                String          @id @default(cuid())
  staffProfileId    String
  rosterShiftId     String?
  venue             String?
  area              String?
  roleTitle         String?
  workDate          DateTime
  clockInAt         DateTime
  clockOutAt        DateTime
  breakMinutes      Int             @default(0)
  notes             String?
  status            TimesheetStatus @default(DRAFT)
  submittedAt       DateTime?
  approvedAt        DateTime?
  approvedById      String?
  rejectedAt        DateTime?
  rejectionReason   String?
  xeroEmployeeId    String?
  xeroEarningsRateId String?
  xeroTimesheetId   String?
  xeroExportBatchId String?
  paymentMethod     String          @default("XERO")
  cashPaidAt        DateTime?
  cashPaidById      String?
  cashPaymentNotes  String?
  exportedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  staffProfile      StaffProfile    @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@index([staffProfileId, workDate])
  @@index([status, workDate])
  @@index([paymentMethod, workDate])
  @@index([xeroExportBatchId])
}

model StaffTipCashEntry {
  id          String   @id @default(cuid())
  venue       String
  serviceDate DateTime
  amountCents Int
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([venue, serviceDate])
  @@index([serviceDate])
}

model StaffTipCardEntry {
  id          String   @id @default(cuid())
  venue       String
  serviceDate DateTime
  amountCents Int
  source      String   @default("control")
  externalId  String?
  importKey   String   @unique
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([serviceDate])
  @@index([venue, serviceDate])
  @@index([source])
}

model StaffTipPaymentRun {
  id           String   @id @default(cuid())
  venue        String
  weekStart    DateTime
  weekEnd      DateTime
  tipPoolCents Int
  status       String   @default("PAID")
  notes        String?
  paidAt       DateTime @default(now())
  paidById     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lines        StaffTipPaymentRunLine[]

  @@index([venue, weekStart, weekEnd])
}

model StaffTipPaymentRunLine {
  id             String             @id @default(cuid())
  paymentRunId   String
  staffProfileId String
  hours          Float
  baseAmountCents Int               @default(0)
  adjustmentCents Int               @default(0)
  amountCents    Int
  excluded       Boolean            @default(false)
  paymentMethod  String             @default("CASH")
  notes          String?
  paidAt         DateTime?
  createdAt      DateTime           @default(now())
  paymentRun     StaffTipPaymentRun @relation(fields: [paymentRunId], references: [id], onDelete: Cascade)
  staffProfile   StaffProfile       @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@index([staffProfileId])
  @@index([paymentRunId])
}

model AppSettings {
  id                   String   @id @default("singleton")
  orgName              String   @default("Alma Hospitality")
  primaryContactName   String?
  primaryContactEmail  String?
  primaryContactPhone  String?
  venues               Json     @default("[]")
  handbookContent      Json     @default("{}")
  onboardingSettings   Json     @default("{}")
  giftCardSettings     Json     @default("{}")
  goveeApiKey          String?
  goveeBaseUrl         String?  @default("https://openapi.api.govee.com")
  notifyEmail          String?
  notifyOverdueIssues  Boolean  @default(true)
  notifyExpiringStaff  Boolean  @default(true)
  notifyOutOfRangeTemp Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model StaffInvite {
  id             String    @id @default(cuid())
  token          String    @unique
  email          String?
  note           String?
  expiresAt      DateTime?
  completedAt    DateTime?
  staffProfileId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([token])
}

model StaffComplianceRecord {
  id                String            @id @default(cuid())
  staffProfileId    String
  recordType        StaffRecordType
  title             String
  issuer            String?
  certificateNumber String?
  issueDate         DateTime?
  expiryDate        DateTime?
  status            StaffRecordStatus @default(PENDING)
  documentName      String?
  documentUrl       String?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  staffProfile      StaffProfile      @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@index([staffProfileId, recordType])
}

model IncidentReport {
  id                String           @id @default(cuid())
  title             String
  incidentType      String
  severity          IssueSeverity    @default(MEDIUM)
  status            IncidentStatus   @default(OPEN)
  occurredAt        DateTime
  reportedBy        String
  venue             String?
  location          String?
  summary           String
  immediateActions  String?
  treatmentProvided String?
  followUpRequired  Boolean          @default(false)
  followUpNotes     String?
  linkedIssueId     String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  linkedIssue       Issue?           @relation(fields: [linkedIssueId], references: [id])
  people            IncidentPerson[]
}

model IncidentPerson {
  id               String         @id @default(cuid())
  incidentReportId String
  name             String
  role             String
  involvement      String
  contactDetails   String?
  injuryDetails    String?
  witnessStatement String?
  createdAt        DateTime       @default(now())
  incidentReport   IncidentReport @relation(fields: [incidentReportId], references: [id], onDelete: Cascade)
}

model TemperatureAsset {
  id                  String                 @id @default(cuid())
  name                String
  venue               String?
  area                String?
  assetType           String
  minTempC            Float
  maxTempC            Float
  integrationProvider String?
  externalDeviceId    String?
  externalModel       String?
  externalSku         String?
  lastReadingAt       DateTime?
  lastSyncAt          DateTime?
  status              TemperatureAssetStatus @default(ACTIVE)
  notes               String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  sensors             TemperatureSensor[]
  logs                TemperatureLog[]
}

model TemperatureIntegration {
  id           String              @id @default(cuid())
  provider     String
  status       String              @default("disconnected")
  apiKeyHint   String?
  baseUrl      String?
  lastSyncedAt DateTime?
  lastError    String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  sensors      TemperatureSensor[]

  @@unique([provider])
}

model TemperatureSensor {
  id               String                 @id @default(cuid())
  integrationId    String
  externalSensorId String
  externalName     String?
  externalModel    String?
  assetId          String?
  lastSeenAt       DateTime?
  lastTemperature  Float?
  lastBatteryLevel Int?
  rawPayload       Json?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  integration      TemperatureIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  asset            TemperatureAsset?      @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@unique([integrationId, externalSensorId])
  @@index([integrationId, externalSensorId])
}

model TemperatureLog {
  id                String               @id @default(cuid())
  assetId           String
  recordedAt        DateTime
  temperatureC      Float
  humidityPct       Float?
  source            TemperatureLogSource @default(MANUAL)
  status            TemperatureLogStatus
  correctiveAction  String?
  recordedBy        String?
  externalReadingId String?
  createdAt         DateTime             @default(now())
  asset             TemperatureAsset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, recordedAt])
}

model LiquorLicence {
  id            String              @id @default(cuid())
  venue         String
  licenceNumber String              @unique
  licenceType   LiquorLicenceType   @default(ON_PREMISES)
  status        LiquorLicenceStatus @default(ACTIVE)
  licensee      String
  issuer        String              @default("NSW Liquor & Gaming")
  issueDate     DateTime?
  expiryDate    DateTime?
  tradingHours  String?
  conditions    String?
  restrictions  String?
  notes         String?
  documentName  String?
  documentUrl   String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([venue])
  @@index([expiryDate])
}

model StockCategory {
  id          String      @id @default(cuid())
  legacyId    String?     @unique
  name        String      @unique
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       StockItem[]
}

model StockItem {
  id             String          @id @default(cuid())
  legacyId       String?         @unique
  sku            String?         @unique
  name           String
  categoryId     String?
  unit           String
  onHand         Float           @default(0)
  parLevel       Float           @default(0)
  reorderPoint   Float?
  avgCostCents   Int?
  status         StockItemStatus @default(ACTIVE)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  category       StockCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  recipeLines    RecipeLine[]
  stocktakeLines StocktakeLine[]
  movements      InventoryMovement[]
  invoiceLines   SupplierInvoiceLine[]

  @@index([categoryId])
  @@index([status])
  @@index([name])
}

model Stocktake {
  id        String          @id @default(cuid())
  legacyId  String?         @unique
  name      String
  venue     String?
  template  String?
  countedAt DateTime
  status    StocktakeStatus @default(IN_PROGRESS)
  notes     String?
  appliedAt DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  lines     StocktakeLine[]
  movements InventoryMovement[]

  @@index([countedAt])
  @@index([status])
}

model StocktakeLine {
  id              String     @id @default(cuid())
  legacyId        String?    @unique
  stocktakeId     String
  itemId          String?
  position        Int        @default(0)
  label           String
  countedQty      Float
  unit            String?
  location        String?
  stockValueCents Int?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  stocktake       Stocktake  @relation(fields: [stocktakeId], references: [id], onDelete: Cascade)
  item            StockItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)
  movements       InventoryMovement[]

  @@index([stocktakeId])
  @@index([itemId])
}

model InventoryMovement {
  id                    String                @id @default(cuid())
  itemId                String
  movementType          InventoryMovementType
  quantityDelta         Float
  quantityBefore        Float
  quantityAfter         Float
  unit                  String?
  sourceStocktakeId     String?
  sourceStocktakeLineId String?
  notes                 String?
  createdAt             DateTime              @default(now())
  item                  StockItem             @relation(fields: [itemId], references: [id], onDelete: Cascade)
  sourceStocktake       Stocktake?            @relation(fields: [sourceStocktakeId], references: [id], onDelete: SetNull)
  sourceStocktakeLine   StocktakeLine?        @relation(fields: [sourceStocktakeLineId], references: [id], onDelete: SetNull)

  @@index([itemId, createdAt])
  @@index([movementType])
  @@index([sourceStocktakeId])
  @@index([sourceStocktakeLineId])
}

model Recipe {
  id            String       @id @default(cuid())
  legacyId      String?      @unique
  title         String
  kind          String?
  category      String?
  subcategory   String?
  venue         String?
  estimatedCost Float        @default(0)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  lines         RecipeLine[]

  @@index([title])
  @@index([category])
}

model RecipeCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  kind        String   @default("FOOD")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([kind])
}

model RecipeLine {
  id             String     @id @default(cuid())
  legacyId       String?    @unique
  recipeId       String
  position       Int        @default(0)
  ingredientName String
  quantity       Float?
  unit           String?
  cost           Float?
  itemId         String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  recipe         Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  item           StockItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([recipeId])
  @@index([itemId])
}

model Supplier {
  id            String         @id @default(cuid())
  legacyId      String?        @unique
  name          String
  contactName   String?
  email         String?
  phone         String?
  website       String?
  address       String?
  accountNumber String?
  paymentTerms  String?
  notes         String?
  status        SupplierStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  invoices      SupplierInvoice[]

  @@index([status])
  @@index([name])
}

model SupplierInvoice {
  id                String                @id @default(cuid())
  source            String                @default("XERO")
  invoiceKey        String
  externalInvoiceId String?
  invoiceNumber     String?
  supplierId        String?
  supplierName      String
  supplierEmail     String?
  venue             String?
  invoiceDate       DateTime?
  dueDate           DateTime?
  currencyCode      String                @default("AUD")
  status            String                @default("DRAFT")
  subtotalCents     Int                   @default(0)
  taxCents          Int                   @default(0)
  totalCents        Int                   @default(0)
  sourceFileName    String?
  sourceFileType    String?
  sourceMetadata    Json?
  importedAt        DateTime              @default(now())
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  supplier          Supplier?             @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  lines             SupplierInvoiceLine[]

  @@unique([source, invoiceKey])
  @@index([venue, invoiceDate])
  @@index([supplierId, invoiceDate])
  @@index([externalInvoiceId])
  @@index([invoiceNumber])
}

model SupplierInvoiceLine {
  id                String           @id @default(cuid())
  supplierInvoiceId String
  lineNumber        Int
  lineKey           String
  externalLineId    String?
  description       String
  itemCode          String?
  accountCode       String?
  quantity          Float            @default(0)
  unit              String?
  unitAmountCents   Int              @default(0)
  lineAmountCents   Int              @default(0)
  taxAmountCents    Int              @default(0)
  itemId            String?
  matchingStatus    String           @default("NEEDS_REVIEW")
  notes             String?
  sourceMetadata    Json?
  costAppliedAt     DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  invoice           SupplierInvoice  @relation(fields: [supplierInvoiceId], references: [id], onDelete: Cascade)
  item              StockItem?       @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@unique([supplierInvoiceId, lineKey])
  @@index([supplierInvoiceId, lineNumber])
  @@index([itemId])
  @@index([matchingStatus])
  @@index([itemCode])
}

model Venue {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  address   String?
  lga       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
