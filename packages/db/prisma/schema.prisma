// Purchase-order lifecycle: order → send → receive → 3-way match against the
// invoice. Closes the loop that "orders are just emails" left open.
enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  MATCHED
  CANCELLED
}

model PurchaseOrder {
  id             String              @id @default(cuid())
