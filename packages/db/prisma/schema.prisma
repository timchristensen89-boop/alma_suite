// @domain: reserve | home: suite
model ReserveTable {
  id           String               @id @default(cuid())
  venue        String
  area         String
  label        String
  minCovers    Int                  @default(1)
  maxCovers    Int
  sortOrder    Int                  @default(0)
  isActive     Boolean              @default(true)
  // Floor-plan geometry. posX/posY/width/height are percentages of the canvas
  // (0–100) so the layout is responsive; null until the table is placed.
  posX         Float?
  posY         Float?
  width        Float?
  height       Float?
  rotation     Int                  @default(0)
  shape        String               @default("rect")
  seats        Int?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  reservations ReserveReservation[]

  @@unique([venue, label])
  @@index([venue, area, sortOrder])
  @@index([isActive])
}

enum ReserveTableCallType {
  WATER
  CLEAR
  ORDER
  CHECK
  ATTENTION
  CUSTOM
}

enum ReserveTableCallStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

// A "table call" raised from the live service map — any host/floor staff can
// send one (water, clear, check, needs attention, or a custom note) and it
// shows to all staff on the board until acknowledged / resolved.
// @domain: reserve | home: suite
model ReserveTableCall {
  id                 String                 @id @default(cuid())
  venue              String
  tableId            String?
  tableLabel         String
  reservationId      String?
  type               ReserveTableCallType   @default(ATTENTION)
  message            String?
  status             ReserveTableCallStatus @default(OPEN)
  createdByName      String?
  createdAt          DateTime               @default(now())
  acknowledgedAt     DateTime?
  acknowledgedByName String?
  resolvedAt         DateTime?
  resolvedByName     String?

  @@index([venue, status, createdAt])
}

// Admin-defined drinks packages a guest can pre-pay for at booking,
// redeemed on arrival (e.g. "Welcome Prosecco", "Cocktail on arrival").
// @domain: reserve | home: suite
model ReserveDrinkPackage {
  id          String   @id @default(cuid())
  venue       String
  name        String
  description String?
  priceCents  Int
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([venue, name])
  @@index([venue, isActive, sortOrder])
}

// Bookable areas per venue (e.g. Alma Avalon: Inside / Outside / Bar;
// St Alma: Dining Room / Bar Counter / Kitchen Counter). Drives the area
// picker in the booking flow, the table editor's area dropdown, and the
// floor-plan area filter. Admin-editable; deactivate via isActive (no delete).
// @domain: reserve | home: suite
model ReserveArea {
  id        String   @id @default(cuid())
  venue     String
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([venue, name])
  @@index([venue, isActive, sortOrder])
}

// @domain: reserve | home: suite
model ReserveReservation {
  id                       String                   @id @default(cuid())
  venue                    String
  serviceDate              DateTime
  servicePeriod            ReserveServicePeriod
  startsAt                 DateTime
  endsAt                   DateTime
  covers                   Int
  status                   ReserveReservationStatus @default(PENDING)
  source                   String                   @default("manager")
  tableId                  String?
  area                     String?
  guestId                  String
  availabilityRuleId       String?
  guestName                String?
  guestEmail               String?
  guestPhone               String?
  occasion                 String?
  notes                    String?
  specialRequests          String?
  internalNotes            String?
  marketingOptIn           Boolean                  @default(false)
  createdById              String?
  cancelledAt              DateTime?
  completedAt              DateTime?
  // Card-on-file for no-show protection (task #2). SetupIntent
  // captures the payment method at booking time; PaymentIntent off
  // the saved method runs when the manager marks no-show.
  stripeCustomerId         String?
  stripeSetupIntentId      String?
  stripePaymentMethodId    String?
  stripePaymentMethodBrand String?
  stripePaymentMethodLast4 String?
  noShowFeeAmountCents     Int?
  noShowFeeChargedAt       DateTime?
  noShowFeePaymentIntentId String?
  noShowFeeError           String?
  // Drinks pre-payment — charged in full at booking via a PaymentIntent.
  // drinksLineItems is the captured snapshot [{packageId,name,priceCents,qty}].
  drinksLineItems          Json?
  drinksTotalCents         Int?
  drinksPaymentIntentId    String?
  drinksPaidAt             DateTime?
  drinksRedeemedAt         DateTime?
  drinksPaymentError       String?
  // In-service state: when the party was seated (turn timer) + course stage
  // (SEATED, ENTREE, MAINS, DESSERT, BILL). Null until seated.
  seatedAt                 DateTime?
  serviceStage             String?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  guest                    ReserveGuest             @relation(fields: [guestId], references: [id], onDelete: Cascade)
  table                    ReserveTable?            @relation(fields: [tableId], references: [id], onDelete: SetNull)
  availabilityRule         ReserveAvailabilityRule? @relation(fields: [availabilityRuleId], references: [id], onDelete: SetNull)
  automationRuns           MarketingAutomationRun[]

  @@index([venue, serviceDate, servicePeriod])
  @@index([startsAt, endsAt])
  @@index([status, serviceDate])
  @@index([guestId])
  @@index([tableId])
  @@index([availabilityRuleId])
}

