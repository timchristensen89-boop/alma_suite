  name                String
  venue               String?
  area                String?
  assetType           String
  minTempC            Float
  maxTempC            Float
  integrationProvider String?
  externalDeviceId    String?
  externalModel       String?
  externalSku         String?
  lastReadingAt       DateTime?
  lastSyncAt          DateTime?
  status              TemperatureAssetStatus @default(ACTIVE)
  notes               String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  sensors             TemperatureSensor[]
  logs                TemperatureLog[]
}

model TemperatureIntegration {
  id           String              @id @default(cuid())
  provider     String
  status       String              @default("disconnected")
  apiKeyHint   String?
  baseUrl      String?
  lastSyncedAt DateTime?
  lastError    String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  sensors      TemperatureSensor[]

  @@unique([provider])
}

model IntegrationConnection {
  id                     String                      @id @default(cuid())
  provider               IntegrationProvider
  scopeType              String                      @default("BUSINESS")
  venueId                String?
  status                 IntegrationConnectionStatus @default(NOT_CONNECTED)
  connectedAt            DateTime?
  disconnectedAt         DateTime?
  lastSyncAt             DateTime?
  lastSyncStatus         IntegrationSyncStatus?
  lastError              String?
  providerAccountId      String?
  providerAccountName    String?
  scopes                 Json                        @default("[]")
  tokenEncrypted         String?
  refreshTokenEncrypted  String?
  tokenSecretRef         String?
  refreshTokenSecretRef  String?
  tokenExpiresAt         DateTime?
  metadata               Json                        @default("{}")
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  updatedByUserId        String?
  syncRuns               IntegrationSyncRun[]
  events                 IntegrationEvent[]
  webhookEvents          IntegrationWebhookEvent[]

  @@index([provider, status])
  @@index([scopeType, venueId])
  @@index([updatedAt])
}

model IntegrationSyncRun {
  id              String                 @id @default(cuid())
  connectionId    String?
  provider        IntegrationProvider
  syncType        IntegrationSyncType
  status          IntegrationSyncStatus
  startedAt       DateTime               @default(now())
  finishedAt      DateTime?
  recordsImported Int                    @default(0)
  recordsUpdated  Int                    @default(0)
  errorSummary    String?
  connection      IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([provider, startedAt])
  @@index([connectionId, startedAt])
}

model IntegrationOAuthState {
  id              String              @id @default(cuid())
  provider        IntegrationProvider
  stateHash       String              @unique
  createdByUserId String
  redirectPath    String?
  expiresAt       DateTime
  consumedAt      DateTime?
  createdAt       DateTime            @default(now())

  @@index([provider, expiresAt])
}

model IntegrationEvent {
  id              String                 @id @default(cuid())
  connectionId    String?
  provider        IntegrationProvider
  eventType       String
  summary         String
  metadata        Json                   @default("{}")
  createdByUserId String?
  createdByName   String?
  createdAt       DateTime               @default(now())
  connection      IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([provider, createdAt])
  @@index([connectionId, createdAt])
}

model IntegrationWebhookEvent {
  id              String                        @id @default(cuid())
  connectionId    String?
  provider        IntegrationProvider
  providerEventId String
  eventType       String?
  status          IntegrationWebhookEventStatus @default(RECEIVED)
  receivedAt      DateTime                      @default(now())
  processedAt     DateTime?
  errorSummary    String?
  connection      IntegrationConnection?        @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@unique([provider, providerEventId])
  @@index([provider, receivedAt])
}

model TemperatureSensor {
  id               String                 @id @default(cuid())
  integrationId    String
  externalSensorId String
  externalName     String?
  externalModel    String?
  assetId          String?
  lastSeenAt       DateTime?
  lastTemperature  Float?
  lastBatteryLevel Int?
  rawPayload       Json?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  integration      TemperatureIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  asset            TemperatureAsset?      @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@unique([integrationId, externalSensorId])
  @@index([integrationId, externalSensorId])
}

model TemperatureLog {
  id                String               @id @default(cuid())
  assetId           String
  recordedAt        DateTime
  temperatureC      Float
  humidityPct       Float?
  source            TemperatureLogSource @default(MANUAL)
  status            TemperatureLogStatus
  correctiveAction  String?
  recordedBy        String?
  externalReadingId String?
  createdAt         DateTime             @default(now())
  asset             TemperatureAsset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, recordedAt])
}

model LiquorLicence {
  id            String              @id @default(cuid())
  venue         String
  licenceNumber String              @unique
  licenceType   LiquorLicenceType   @default(ON_PREMISES)
  status        LiquorLicenceStatus @default(ACTIVE)
  licensee      String
  issuer        String              @default("NSW Liquor & Gaming")
  issueDate     DateTime?
  expiryDate    DateTime?
  tradingHours  String?
  conditions    String?
  restrictions  String?
  notes         String?
  documentName  String?
  documentUrl   String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([venue])
  @@index([expiryDate])
}

model StockCategory {
  id          String      @id @default(cuid())
  legacyId    String?     @unique
  name        String      @unique
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       StockItem[]
}

model StockItem {
  id             String          @id @default(cuid())
  legacyId       String?         @unique
  sku            String?         @unique
  name           String
  categoryId     String?
  unit           String
  onHand         Float           @default(0)
  parLevel       Float           @default(0)
  reorderPoint   Float?
  avgCostCents   Int?
  status         StockItemStatus @default(ACTIVE)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  category       StockCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  venueStock     VenueStockItem[]
  recipeLines    RecipeLine[]
  stocktakeLines StocktakeLine[]
  movements      InventoryMovement[]
  invoiceLines   SupplierInvoiceLine[]

  @@index([categoryId])
  @@index([status])
  @@index([name])
}

model VenueStockItem {
  id           String    @id @default(cuid())
  venue        String
  stockItemId  String
  parLevel     Float?
  reorderPoint Float?
  onHand       Float?
  unitOverride String?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  stockItem    StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@unique([venue, stockItemId])
  @@index([venue])
  @@index([stockItemId])
  @@index([venue, active])
  @@index([venue, reorderPoint])
  @@index([updatedAt])
}

model Stocktake {
  id                String          @id @default(cuid())
  legacyId          String?         @unique
  name              String
  venue             String?
  template          String?
  countedAt         DateTime
  status            StocktakeStatus @default(IN_PROGRESS)
  notes             String?
  appliedAt         DateTime?
  submittedAt       DateTime?
  submittedByUserId String?
  reviewedAt        DateTime?
  reviewedByUserId  String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  lines             StocktakeLine[]
  movements         InventoryMovement[]
  shiftTaskAssignments ShiftTaskAssignment[]

  @@index([countedAt])
  @@index([status])
  @@index([venue, status])
  @@index([submittedAt])
  @@index([reviewedAt])
}

model StocktakeLine {
  id              String     @id @default(cuid())
  legacyId        String?    @unique
  stocktakeId     String
  itemId          String?
  position        Int        @default(0)
  label           String
  countedQty      Float
  unit            String?
  location        String?
  stockValueCents Int?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  stocktake       Stocktake  @relation(fields: [stocktakeId], references: [id], onDelete: Cascade)
  item            StockItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)
  movements       InventoryMovement[]

  @@index([stocktakeId])
  @@index([itemId])
}

model InventoryMovement {
  id                    String                @id @default(cuid())
  itemId                String
  movementType          InventoryMovementType
  quantityDelta         Float
  quantityBefore        Float
  quantityAfter         Float
  unit                  String?
  sourceStocktakeId     String?
  sourceStocktakeLineId String?
  notes                 String?
  createdAt             DateTime              @default(now())
  item                  StockItem             @relation(fields: [itemId], references: [id], onDelete: Cascade)
  sourceStocktake       Stocktake?            @relation(fields: [sourceStocktakeId], references: [id], onDelete: SetNull)
  sourceStocktakeLine   StocktakeLine?        @relation(fields: [sourceStocktakeLineId], references: [id], onDelete: SetNull)

  @@index([itemId, createdAt])
  @@index([movementType])
  @@index([sourceStocktakeId])
  @@index([sourceStocktakeLineId])
}

model Recipe {
  id            String       @id @default(cuid())
  legacyId      String?      @unique
  title         String
  kind          String?
  category      String?
  subcategory   String?
  venue         String?
  yieldQuantity Float?
  yieldUnit     String?
  estimatedCost Float        @default(0)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  lines         RecipeLine[] @relation("RecipeLines")
  usedByLines   RecipeLine[] @relation("SubRecipeLines")

  @@index([title])
  @@index([category])
}

model RecipeCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  kind        String   @default("FOOD")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([kind])
}

model RecipeLine {
  id             String     @id @default(cuid())
  legacyId       String?    @unique
  recipeId       String
  position       Int        @default(0)
  ingredientName String
  quantity       Float?
  unit           String?
  cost           Float?
  itemId         String?
  subRecipeId    String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  recipe         Recipe     @relation("RecipeLines", fields: [recipeId], references: [id], onDelete: Cascade)
  item           StockItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)
  subRecipe      Recipe?    @relation("SubRecipeLines", fields: [subRecipeId], references: [id], onDelete: SetNull)

  @@index([recipeId])
  @@index([itemId])
  @@index([subRecipeId])
}

model Supplier {
  id            String         @id @default(cuid())
  legacyId      String?        @unique
  name          String
  contactName   String?
  email         String?
  phone         String?
  website       String?
  address       String?
  accountNumber String?
  paymentTerms  String?
  notes         String?
  status        SupplierStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  invoices      SupplierInvoice[]

  @@index([status])
  @@index([name])
}

model SupplierInvoice {
  id                String                @id @default(cuid())
  source            String                @default("XERO")
  invoiceKey        String
  externalInvoiceId String?
  invoiceNumber     String?
  supplierId        String?
  supplierName      String
  supplierEmail     String?
  venue             String?
  invoiceDate       DateTime?
  dueDate           DateTime?
  currencyCode      String                @default("AUD")
  status            String                @default("DRAFT")
  subtotalCents     Int                   @default(0)
  taxCents          Int                   @default(0)
  totalCents        Int                   @default(0)
  sourceFileName    String?
  sourceFileType    String?
  sourceMetadata    Json?
  importedAt        DateTime              @default(now())
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  supplier          Supplier?             @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  lines             SupplierInvoiceLine[]

  @@unique([source, invoiceKey])
  @@index([venue, invoiceDate])
  @@index([supplierId, invoiceDate])
  @@index([externalInvoiceId])
  @@index([invoiceNumber])
}

model SupplierInvoiceLine {
  id                String           @id @default(cuid())
  supplierInvoiceId String
  lineNumber        Int
  lineKey           String
  externalLineId    String?
  description       String
  itemCode          String?
  accountCode       String?
  quantity          Float            @default(0)
  unit              String?
  unitAmountCents   Int              @default(0)
  lineAmountCents   Int              @default(0)
  taxAmountCents    Int              @default(0)
  itemId            String?
  matchingStatus    String           @default("NEEDS_REVIEW")
  notes             String?
  sourceMetadata    Json?
  costAppliedAt     DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  invoice           SupplierInvoice  @relation(fields: [supplierInvoiceId], references: [id], onDelete: Cascade)
  item              StockItem?       @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@unique([supplierInvoiceId, lineKey])
  @@index([supplierInvoiceId, lineNumber])
  @@index([itemId])
  @@index([matchingStatus])
  @@index([itemCode])
}

model Venue {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  address   String?
  lga       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


enum CommsThreadCategory {
  INBOX
  VENUE
  ANNOUNCEMENT
  HANDOVER
  TASK
  ALERT
  GENERAL
}

enum CommsPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum CommsAlertType {
  ROSTER_FORECAST_COGS_HIGH
  STOCK_VARIANCE_HIGH
  FRIDGE_TEMP_BREACH
  STAFF_DOCUMENT_EXPIRING
  CHECKLIST_CRITICAL_FAIL
  AUDIT_CRITICAL_ISSUE
  GENERAL
}

enum CommsAlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum CommsRecipientMode {
  STAFF
  VENUE
  ROLE
  MANAGERS
  ADMINS
  CUSTOM_EMAILS
}

model CommsThread {
  id          String              @id @default(cuid())
  subject     String
  venue       String?
  category    CommsThreadCategory @default(GENERAL)
  priority    CommsPriority       @default(NORMAL)
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  archivedAt  DateTime?

  messages    CommsMessage[]
  recipients  CommsRecipient[]
  links       CommsLink[]
  alertEvents CommsAlertEvent[]

  @@index([venue, category])
  @@index([priority])
  @@index([archivedAt])
}

model CommsMessage {
  id          String    @id @default(cuid())
  threadId    String
  body        String
  createdById String?
  createdAt   DateTime  @default(now())
  editedAt    DateTime?

  thread      CommsThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  attachments CommsAttachment[]

  @@index([threadId, createdAt])
}

model CommsRecipient {
  id             String    @id @default(cuid())
  threadId       String
  staffProfileId String?
  venue          String?
  role           String?
  readAt         DateTime?
  acknowledgedAt DateTime?
  actionRequired Boolean   @default(false)
  dueAt          DateTime?

  thread         CommsThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([staffProfileId, readAt])
  @@index([venue, readAt])
  @@index([role, readAt])
  @@index([actionRequired, dueAt])
}

model CommsAttachment {
  id           String   @id @default(cuid())
  messageId    String
  documentName String
  documentUrl  String
  mimeType     String?
  createdAt    DateTime @default(now())

  message      CommsMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model CommsLink {
  id         String @id @default(cuid())
  threadId   String
  entityType String
  entityId   String

  thread     CommsThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([entityType, entityId])
}

model CommsAlertRule {
  id              String             @id @default(cuid())
  name            String
  enabled         Boolean            @default(true)
  venue           String?
  alertType       CommsAlertType
  thresholdValue  Float?
  thresholdUnit   String?
  recipientMode   CommsRecipientMode @default(MANAGERS)
  recipientEmails Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  events          CommsAlertEvent[]

  @@index([enabled, alertType])
  @@index([venue])
}

model CommsAlertEvent {
  id             String              @id @default(cuid())
  ruleId         String?
  threadId       String?
  alertType      CommsAlertType
  venue          String?
  severity       CommsAlertSeverity   @default(WARNING)
  subject        String
  body           String
  sourceType     String?
  sourceId       String?
  value          Float?
  thresholdValue Float?
  emailedAt      DateTime?
  createdAt      DateTime            @default(now())

  rule           CommsAlertRule?      @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  thread         CommsThread?         @relation(fields: [threadId], references: [id], onDelete: SetNull)

  @@index([alertType, createdAt])
  @@index([venue, createdAt])
  @@index([severity])
}
