generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  RESOLVED
  CLOSED
}

enum ChecklistRunStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
}

enum ChecklistItemResult {
  PENDING
  PASS
  FAIL
  NA
}

enum StaffRecordType {
  RSA
  RSG
  FSS
  FIRST_AID
  FOOD_SAFETY
  ALLERGEN
  TRAINING
  OTHER
}

enum StaffRecordStatus {
  PENDING
  APPROVED
  EXPIRED
}

enum IncidentStatus {
  OPEN
  UNDER_REVIEW
  CLOSED
}

enum TemperatureAssetStatus {
  ACTIVE
  INACTIVE
}

enum TemperatureLogSource {
  MANUAL
  GOVEE
}

enum TemperatureLogStatus {
  IN_RANGE
  OUT_OF_RANGE
}

enum LiquorLicenceType {
  HOTEL
  ON_PREMISES
  SMALL_BAR
  CLUB
  PACKAGED
  PRODUCER_WHOLESALER
  LIMITED
  OUTDOOR_SEATING
  FOOD_BUSINESS
  FOOTPATH_DINING
  MUSIC_ENTERTAINMENT
  SIGNAGE
  FIRE_SAFETY
  WASTE_TRADE
  OTHER
}

enum LiquorLicenceStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  PENDING
}

enum StockItemStatus {
  ACTIVE
  ARCHIVED
}

enum SupplierStatus {
  ACTIVE
  ARCHIVED
}

enum StocktakeStatus {
  IN_PROGRESS
  SUBMITTED
}

enum ShiftTaskType {
  CHECKLIST
  STOCKTAKE
  AUDIT
  INCIDENT_CHECK
}

enum ShiftTaskDueTiming {
  BEFORE_SHIFT_START
  DURING_SHIFT
  BEFORE_SHIFT_END
  AFTER_SHIFT_END
}

enum ShiftTaskAssignmentTarget {
  ASSIGNED_STAFF
  VENUE_QUEUE
  MANAGER_ON_DUTY
  ALL_ON_SHIFT
}

enum ShiftTaskAssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum InventoryMovementType {
  STOCKTAKE_ADJUSTMENT
  STOCKTAKE_CORRECTION
  STOCKTAKE_REVERSAL
}

enum AlmaAppId {
  COMPLIANCE
  STOCK
  STAFF
  REPORTS
  RESERVE
  MARKETING
  GIFTCARDS
  TRAINING
  SETTINGS
}

enum StaffAppAccessStatus {
  ENABLED
  DISABLED
  PENDING
}

enum StaffAccountType {
  HUMAN
  VENUE_DEVICE
}

enum RosterShiftStatus {
  DRAFT
  PUBLISHED
  COMPLETED
  CANCELLED
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  EXPORTED
}

enum StaffClockSessionStatus {
  OPEN
  CLOSED
  EXCEPTION
}

enum StaffClockEventType {
  CLOCK_IN
  START_BREAK
  END_BREAK
  CLOCK_OUT
  MANAGER_REVIEW
}

enum TrainingModuleStatus {
  ACTIVE
  ARCHIVED
}

enum StaffTrainingStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

enum ReserveReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ReserveServicePeriod {
  BREAKFAST
  LUNCH
  DINNER
  EVENT
}

enum MarketingChannel {
  EMAIL
  SMS
}

enum MarketingCampaignStatus {
  DRAFT
  READY
  SCHEDULED
  SENDING
  SENT
  CANCELLED
  ARCHIVED
}

enum GuestTagType {
  MANUAL
  AUTOMATIC
  SYSTEM
  CUSTOM
}

enum GuestTagAssignmentSource {
  MANUAL
  AUTOMATIC
  SYSTEM
}

enum MarketingEmailTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum MarketingAutomationTriggerType {
  FIRST_VISIT_COMPLETED
  REPEAT_VISIT
  LAPSED_GUEST
  BIRTHDAY_UPCOMING
  RESERVATION_CREATED
  RESERVATION_CANCELLED
  NO_SHOW
  BIG_SPENDER
}

enum MarketingAutomationRunStatus {
  PENDING
  SKIPPED
  SENT
  FAILED
  SIMULATED
}

enum MarketingContentAssetType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum MarketingContentAssetStorageProvider {
  LOCAL
  CLOUD_STORAGE
  EXTERNAL_URL
}

enum MarketingContentAssetStatus {
  DRAFT
  READY
  ARCHIVED
}

enum MarketingContentAssetSource {
  UPLOAD
  IMPORT
  GENERATED
}

enum MarketingContentPostStatus {
  IDEA
  DRAFT
  NEEDS_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
  ARCHIVED
}

enum MarketingSocialPlatform {
  FACEBOOK
  INSTAGRAM
  TIKTOK
}

enum MarketingSocialAccountStatus {
  SETUP_REQUIRED
  CONNECTED
  EXPIRED
  DISABLED
  ERROR
}

enum MarketingContentPublishStatus {
  SIMULATED
  QUEUED
  SKIPPED
  PUBLISHED
  FAILED
}

enum MarketingContentPublishMode {
  SIMULATION
  LIVE
}

enum GoogleReserveIntegrationStatus {
  SETUP_REQUIRED
  PENDING
  ACTIVE
  ERROR
}

enum IntegrationProvider {
  SQUARE
  XERO
}

enum IntegrationConnectionStatus {
  NOT_CONNECTED
  CONNECTED
  ERROR
  REVOKED
}

enum IntegrationSyncType {
  MANUAL
  WEBHOOK
  SCHEDULED
  BACKFILL
  TEST
  OAUTH_CALLBACK
}

enum IntegrationSyncStatus {
  RUNNING
  SUCCESS
  ERROR
}

enum IntegrationWebhookEventStatus {
  RECEIVED
  DUPLICATE
  IGNORED
  ERROR
}

enum GiftCardStatus {
  PENDING_PAYMENT
  ACTIVE
  REDEEMED
  CANCELLED
  EXPIRED
}

enum GiftCardRedemptionStatus {
  COMPLETED
  VOIDED
}

enum GiftCardPromoDiscountType {
  PERCENT
  FIXED_AMOUNT
}

enum SuiteChatChannelType {
  GENERAL
  VENUE
  AREA
  GROUP
  DIRECT
}

model Issue {
  id              String           @id @default(cuid())
  legacyId        String?          @unique
  title           String
  description     String
  severity        IssueSeverity
  category        String
  status          IssueStatus      @default(OPEN)
  assignee        String?
  dueDate         DateTime?
  notes           String?
  resolutionNotes String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  evidence        IssueEvidence[]
  activities      IssueActivity[]
  checklistLinks  ChecklistItem[]
  auditLinks      AuditFinding[]
  incidentLinks   IncidentReport[]
}

model IssueEvidence {
  id        String   @id @default(cuid())
  legacyId  String?  @unique
  issueId   String
  name      String
  url       String
  fileType  String?
  createdAt DateTime @default(now())
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
}

model IssueActivity {
  id        String   @id @default(cuid())
  legacyId  String?  @unique
  issueId   String
  action    String
  message   String
  actor     String
  createdAt DateTime @default(now())
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
}

model ChecklistTemplate {
  id        String                  @id @default(cuid())
  legacyId  String?                 @unique
  name      String
  area      String?
  items     ChecklistItemTemplate[]
  runs      ChecklistRun[]
  shiftTaskRules ShiftTaskRule[]
  shiftTaskAssignments ShiftTaskAssignment[]
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
}

model ChecklistItemTemplate {
  id          String            @id @default(cuid())
  legacyId    String?           @unique
  templateId  String
  label       String
  description String?
  position    Int
  template    ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ChecklistRun {
  id          String             @id @default(cuid())
  legacyId    String?            @unique
  templateId  String
  runDate     DateTime           @default(now())
  status      ChecklistRunStatus @default(OPEN)
  area        String?
  performedBy String?
  notes       String?
  template    ChecklistTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items       ChecklistItem[]
  shiftTaskAssignments ShiftTaskAssignment[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model ChecklistItem {
  id             String              @id @default(cuid())
  legacyId       String?             @unique
  runId          String
  templateItemId String?
  label          String
  description    String?
  position       Int
  result         ChecklistItemResult @default(PENDING)
  notes          String?
  linkedIssueId  String?
  run            ChecklistRun        @relation(fields: [runId], references: [id], onDelete: Cascade)
  linkedIssue    Issue?              @relation(fields: [linkedIssueId], references: [id])
}

model AuditTemplate {
  id        String                 @id @default(cuid())
  legacyId  String?                @unique
  name      String
  sections  AuditTemplateSection[]
  runs      AuditRun[]
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
}

model AuditTemplateSection {
  id          String        @id @default(cuid())
  legacyId    String?       @unique
  templateId  String
  title       String
  description String?
  position    Int
  template    AuditTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model AuditRun {
  id         String         @id @default(cuid())
  legacyId   String?        @unique
  templateId String
  title      String
  score      Float?
  summary    String?
  runDate    DateTime       @default(now())
  template   AuditTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  findings   AuditFinding[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model AuditFinding {
  id            String   @id @default(cuid())
  legacyId      String?  @unique
  auditRunId    String
  sectionTitle  String
  finding       String
  score         Float?
  linkedIssueId String?
  auditRun      AuditRun @relation(fields: [auditRunId], references: [id], onDelete: Cascade)
  linkedIssue   Issue?   @relation(fields: [linkedIssueId], references: [id])
}

model StaffProfile {
  id               String                  @id @default(cuid())
  firstName        String
  lastName         String
  roleTitle        String
  email            String?                 @unique
  phone            String?
  venue            String?
  employmentStatus String                  @default("ACTIVE")
  accountType      StaffAccountType        @default(HUMAN)
  startDate        DateTime?
  dateOfBirth      DateTime?
  addressLine1     String?
  addressLine2     String?
  suburb           String?
  state            String?
  postcode         String?
  emergencyContactName         String?
  emergencyContactRelationship String?
  emergencyContactPhone        String?
  employmentType   String?
  payType          String?
  payRateCents     Int?
  payAward         String?
  taxFileNumber    String?
  taxResidencyStatus String?
  taxFreeThreshold Boolean?
  hasStudyTrainingLoan Boolean?
  superFundName    String?
  superFundAbn     String?
  superFundUsi     String?
  superMemberNumber String?
  bankAccountName  String?
  bankBsb          String?
  bankAccountNumber String?
  visaStatus       String?
  visaSubclass     String?
  visaExpiryDate   DateTime?
  workRightsNotes  String?
  xeroEmployeeId   String?
  xeroPayrollCalendarId String?
  xeroEarningsRateId String?
  trainingLevel    Int                     @default(0)
  trainingPayRateCents Int?
  notes            String?
  mergedIntoStaffProfileId String?
  mergedAt         DateTime?
  mergedByUserId   String?
  passwordHash     String?
  pinHash          String?
  pinUpdatedAt     DateTime?
  pinFailedAttempts Int                    @default(0)
  pinLockedUntil   DateTime?
  pinLastFailedAt  DateTime?
  isAdmin          Boolean                 @default(false)
  lastLoginAt      DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  records          StaffComplianceRecord[]
  hrRecords        StaffHrRecord[]
  managerNotes     StaffManagerNote[]
  payProfile       StaffPayProfile?
  managementEvents StaffManagementEvent[]
  leaveRequests    StaffLeaveRequest[]
  passwordResetTokens StaffPasswordResetToken[]
  appAccess        StaffAppAccess[]
  roleTemplateId   String?
  roleTemplate     StaffRoleTemplate?      @relation(fields: [roleTemplateId], references: [id], onDelete: SetNull)
  rosterShifts     RosterShift[]
  shiftTaskAssignments ShiftTaskAssignment[]
  shiftConfirmations StaffShiftConfirmation[]
  clockSessions    StaffClockSession[]
  clockEvents      StaffClockEvent[]
  timesheets       Timesheet[]
  trainingRecords  StaffTrainingRecord[]
  tipPaymentRunLines StaffTipPaymentRunLine[]

  @@index([venue])
  @@index([accountType, venue])
  @@index([roleTemplateId])
  @@index([mergedIntoStaffProfileId])
  @@index([xeroEmployeeId])
}

model StaffRoleTemplate {
  id            String                    @id @default(cuid())
  name          String                    @unique
  description   String?
  roleTitle     String?
  venue         String?
  isActive      Boolean                   @default(true)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  access        StaffRoleTemplateAccess[]
  staffProfiles StaffProfile[]

  @@index([isActive])
  @@index([venue])
}

model StaffRoleTemplateAccess {
  id             String               @id @default(cuid())
  roleTemplateId String
  appId          AlmaAppId
  status         StaffAppAccessStatus @default(DISABLED)
  role           String               @default("USER")
  permissions    Json                 @default("{}")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  roleTemplate   StaffRoleTemplate    @relation(fields: [roleTemplateId], references: [id], onDelete: Cascade)

  @@unique([roleTemplateId, appId])
  @@index([appId, status])
}

model StaffManagerNote {
  id             String       @id @default(cuid())
  staffProfileId String
  body           String
  createdById    String
  createdByName  String
  createdByEmail String?
  createdAt      DateTime     @default(now())
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@index([staffProfileId, createdAt])
  @@index([createdById])
}

model StaffPayProfile {
  id                            String       @id @default(cuid())
  staffProfileId                String       @unique
  awardCode                     String
  awardName                     String
  awardClassification           String
  employmentType                String
  payMode                       String       @default("AWARD")
  awardRateSource               String
  awardRateEffectiveFrom        DateTime
  payGuidePublishedAt           DateTime
  rateSetVersion                String
  ordinaryHourlyRateCents       Int
  casualLoadedHourlyRateCents   Int?
  manualFullTimePayAmountCents  Int?
  manualFullTimePayFrequency    String?
  manualFullTimePayNote         String?
  payUpdatedAt                  DateTime     @default(now())
  payUpdatedByUserId            String?
  createdAt                     DateTime     @default(now())
  updatedAt                     DateTime     @updatedAt
  staffProfile                  StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@index([awardCode, awardClassification])
  @@index([payUpdatedAt])
}

model StaffManagementEvent {
  id             String       @id @default(cuid())
  staffProfileId String
  eventType      String
  summary        String
  metadata       Json         @default("{}")
  createdById    String?
  createdByName  String?
  createdByEmail String?
  createdAt      DateTime     @default(now())
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@index([staffProfileId, createdAt])
  @@index([eventType, createdAt])
}

model StaffHrRecord {
  id             String       @id @default(cuid())
  staffProfileId String
  recordType     String
  title          String
  status         String       @default("STORED")
  issueDate      DateTime?
  effectiveDate  DateTime?
  expiryDate     DateTime?
  followUpDate   DateTime?
  reason         String?
  oldRateCents   Int?
  newRateCents   Int?
  documentName   String?
  documentUrl    String?
  notes          String?
  createdById    String?
  updatedById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@index([staffProfileId, recordType])
  @@index([recordType, status])
  @@index([expiryDate])
  @@index([followUpDate])
}

model StaffHrDocumentTemplate {
  id              String   @id @default(cuid())
  name            String
  recordType      String
  status          String   @default("DRAFT")
  body            String
  variables       Json     @default("[]")
  optionalClauses Json     @default("[]")
  createdById     String?
  updatedById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([recordType, status])
  @@index([status])
  @@index([updatedAt])
}

model StaffLeaveRequest {
  id                String       @id @default(cuid())
  staffProfileId    String
  type              String
  status            String       @default("PENDING")
  startDate         DateTime
  endDate           DateTime
  notes             String?
  managerNote       String?
  requestedByUserId String?
  reviewedByUserId  String?
  reviewedAt        DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  staffProfile      StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@index([staffProfileId, startDate])
  @@index([status, startDate])
  @@index([startDate, endDate])
}

model StaffPasswordResetToken {
  id              String       @id @default(cuid())
  staffProfileId  String
  tokenHash       String       @unique
  requestedById   String?
  requestedByName String?
  requestedByEmail String?
  requestIp       String?
  userAgent       String?
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime     @default(now())
  staffProfile    StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@index([staffProfileId, createdAt])
  @@index([expiresAt])
}

model StaffAppAccess {
  id             String               @id @default(cuid())
  staffProfileId String
  appId          AlmaAppId
  status         StaffAppAccessStatus @default(DISABLED)
  role           String               @default("USER")
  permissions    Json                 @default("{}")
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  staffProfile   StaffProfile         @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@unique([staffProfileId, appId])
  @@index([appId, status])
}

model SuiteAnnouncement {
  id            String     @id @default(cuid())
  title         String
  body          String
  audience      String     @default("ALL")
  appId         AlmaAppId?
  venue         String?
  pinned        Boolean    @default(false)
  createdById   String?
  createdByName String?
  updatedById   String?
  updatedByName String?
  deletedAt     DateTime?
  deletedById   String?
  deletedByName String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  expiresAt     DateTime?

  @@index([audience, appId, venue, createdAt])
  @@index([expiresAt])
  @@index([deletedAt])
}

model SuiteChatChannel {
  id                String               @id @default(cuid())
  name              String
  description       String?
  channelKey        String               @unique
  type              SuiteChatChannelType @default(GROUP)
  appId             AlmaAppId?
  venue             String?
  groupKey          String?
  isActive          Boolean              @default(true)
  readPermission    String?
  postPermission    String?
  directMessagesAllowed Boolean          @default(false)
  createdById       String?
  createdByName     String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  messages          SuiteChatMessage[]

  @@index([type, appId, venue, isActive])
  @@index([groupKey])
}

model SuiteChatMessage {
  id            String     @id @default(cuid())
  channelId     String?
  channel       String     @default("general")
  channelType   SuiteChatChannelType @default(GENERAL)
  appId         AlmaAppId?
  venue         String?
  recipientId   String?
  recipientName String?
  body          String
  createdById   String?
  createdByName String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  editedAt      DateTime?
  deletedAt     DateTime?
  deletedById   String?
  deletedByName String?
  channelRef    SuiteChatChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([channel, appId, venue, createdAt])
  @@index([channelId, createdAt])
  @@index([createdById, createdAt])
  @@index([recipientId, createdAt])
  @@index([deletedAt])
}

model TrainingModule {
  id               String               @id @default(cuid())
  title            String
  description      String?
  category         String?
  level            Int                  @default(1)
  estimatedMinutes Int?
  status           TrainingModuleStatus @default(ACTIVE)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  records          StaffTrainingRecord[]

  @@index([status, level])
  @@index([category])
}

model TrainingLevelPayRule {
  id           String   @id @default(cuid())
  level        Int      @unique
  label        String
  payRateCents Int
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model StaffTrainingRecord {
  id             String              @id @default(cuid())
  staffProfileId String
  moduleId       String
  status         StaffTrainingStatus @default(ASSIGNED)
  assignedAt     DateTime            @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  expiresAt      DateTime?
  score          Float?
  evidenceName   String?
  evidenceUrl    String?
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  staffProfile   StaffProfile        @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  module         TrainingModule      @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([staffProfileId, moduleId])
  @@index([staffProfileId, status])
  @@index([moduleId, status])
}

model RosterShift {
  id             String            @id @default(cuid())
  staffProfileId String
  venue          String?
  area           String?
  roleTitle      String?
  startsAt       DateTime
  endsAt         DateTime
  breakMinutes   Int               @default(0)
  status         RosterShiftStatus @default(DRAFT)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  staffProfile   StaffProfile      @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  shiftConfirmations StaffShiftConfirmation[]
  shiftTaskAssignments ShiftTaskAssignment[]
  clockSessions  StaffClockSession[]

  @@index([staffProfileId, startsAt])
  @@index([startsAt, endsAt])
}

model ShiftTaskRule {
  id                 String                    @id @default(cuid())
  name               String
  enabled            Boolean                   @default(true)
  venue              String?
  matchRoleTitle     String?
  matchArea          String?
  matchShiftLabel    String?
  startBeforeMinutes Int?
  startAfterMinutes  Int?
  endBeforeMinutes   Int?
  endAfterMinutes    Int?
  daysOfWeek         Json?
  taskType           ShiftTaskType
  checklistTemplateId String?
  stocktakeTemplate  String?
  dueTiming          ShiftTaskDueTiming        @default(DURING_SHIFT)
  dueOffsetMinutes   Int?
  assignmentTarget   ShiftTaskAssignmentTarget @default(ASSIGNED_STAFF)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  checklistTemplate  ChecklistTemplate?        @relation(fields: [checklistTemplateId], references: [id], onDelete: SetNull)
  assignments        ShiftTaskAssignment[]

  @@index([enabled, venue])
  @@index([taskType])
  @@index([checklistTemplateId])
}

model ShiftTaskAssignment {
  id                  String                    @id @default(cuid())
  assignmentKey       String                    @unique
  ruleId              String
  rosterShiftId       String?
  staffProfileId      String?
  venue               String?
  taskType            ShiftTaskType
  checklistTemplateId String?
  checklistRunId      String?
  stocktakeId         String?
  status              ShiftTaskAssignmentStatus @default(PENDING)
  dueAt               DateTime?
  completedAt         DateTime?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  rule                ShiftTaskRule             @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  rosterShift         RosterShift?              @relation(fields: [rosterShiftId], references: [id], onDelete: SetNull)
  staffProfile        StaffProfile?             @relation(fields: [staffProfileId], references: [id], onDelete: SetNull)
  checklistTemplate   ChecklistTemplate?        @relation(fields: [checklistTemplateId], references: [id], onDelete: SetNull)
  checklistRun        ChecklistRun?             @relation(fields: [checklistRunId], references: [id], onDelete: SetNull)
  stocktake           Stocktake?                @relation(fields: [stocktakeId], references: [id], onDelete: SetNull)

  @@index([ruleId])
  @@index([rosterShiftId])
  @@index([staffProfileId])
  @@index([venue, status])
  @@index([dueAt])
