  STOCK_VARIANCE_HIGH
  FRIDGE_TEMP_BREACH
  STAFF_DOCUMENT_EXPIRING
  CHECKLIST_CRITICAL_FAIL
  AUDIT_CRITICAL_ISSUE
  GENERAL
}

