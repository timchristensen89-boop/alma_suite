    "migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "migrate:production": "prisma migrate deploy --schema prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts",
    "seed:prod": "tsx prisma/seed-prod.ts",
    "seed:beta": "tsx prisma/seed-beta.ts",
    "create:master-user": "tsx prisma/create-master-user.ts",
