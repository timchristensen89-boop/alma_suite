    "import:sevenrooms-reserve": "tsx prisma/import-sevenrooms-reserve.ts",
    "import:legacy": "tsx prisma/import-legacy.ts",
    "import:legacy-stock": "tsx prisma/import-legacy-stock.ts",
    "extract:legacy-compliance": "tsx prisma/extract-legacy-compliance.ts",
