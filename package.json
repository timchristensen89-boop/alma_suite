{
  "name": "alma-suite-v18",
  "private": true,
  "version": "18.0.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm db:prepare && concurrently \"pnpm --filter @alma/api dev\" \"pnpm --filter @alma/web dev\"",
    "dev:api": "pnpm --filter @alma/api dev",
    "dev:web": "pnpm --filter @alma/web dev",
    "dev:stock": "concurrently \"pnpm --filter @alma/stock-api dev\" \"pnpm --filter @alma/stock-web dev\"",
    "dev:stock-api": "pnpm --filter @alma/stock-api dev",
    "dev:stock-web": "pnpm --filter @alma/stock-web dev",
    "dev:staff": "concurrently \"pnpm --filter @alma/api dev\" \"pnpm --filter @alma/staff-web dev\"",
    "dev:staff-web": "pnpm --filter @alma/staff-web dev",
    "dev:reports": "concurrently \"pnpm --filter @alma/api dev\" \"pnpm --filter @alma/stock-api dev\" \"pnpm --filter @alma/reports-web dev\"",
    "dev:reports-web": "pnpm --filter @alma/reports-web dev",
    "dev:reserve": "concurrently \"pnpm --filter @alma/api dev\" \"pnpm --filter @alma/reserve-web dev\"",
    "dev:reserve-web": "pnpm --filter @alma/reserve-web dev",
    "dev:marketing": "concurrently \"pnpm --filter @alma/api dev\" \"pnpm --filter @alma/marketing-web dev\"",
    "dev:marketing-web": "pnpm --filter @alma/marketing-web dev",
    "dev:giftcards": "concurrently \"pnpm --filter @alma/api dev\" \"pnpm --filter @alma/giftcards-web dev\"",
    "dev:giftcards-web": "pnpm --filter @alma/giftcards-web dev",
    "db:up": "docker compose up -d postgres",
    "db:prepare": "bash ./scripts/prepare-postgres.sh",
    "db:down": "docker compose down",
    "db:generate": "pnpm --filter @alma/db generate",
    "db:migrate": "pnpm db:prepare && pnpm --filter @alma/db migrate",
    "db:migrate:deploy": "pnpm --filter @alma/db migrate:deploy",
    "db:migrate:production": "pnpm --filter @alma/db migrate:production",
    "db:seed": "pnpm --filter @alma/db seed",
    "db:seed:prod": "pnpm --filter @alma/db seed:prod",
    "db:seed:beta": "pnpm --filter @alma/db seed:beta",
    "db:create:master-user": "pnpm --filter @alma/db create:master-user",
    "db:import:alma-control": "pnpm --filter @alma/db import:alma-control",
    "db:import:compliance-documents": "pnpm --filter @alma/db import:compliance-documents",
    "db:import:deputy-roster": "pnpm --filter @alma/db import:deputy-roster --",
    "db:import:sevenrooms-reserve": "pnpm --filter @alma/db import:sevenrooms-reserve --",
    "db:import:sevenrooms-marketing": "pnpm --filter @alma/db import:sevenrooms-marketing --",
    "db:import:legacy": "pnpm --filter @alma/db import:legacy --",
    "db:import:legacy-stock": "pnpm --filter @alma/db import:legacy-stock --",
    "db:extract:legacy-compliance": "pnpm --filter @alma/db extract:legacy-compliance --",
    "db:extract:legacy-stock": "pnpm --filter @alma/db extract:legacy-stock --",
    "db:sync:govee": "pnpm --filter @alma/db sync:govee-temperature --",
    "prebuild": "pnpm db:generate",
    "gcp-build": "pnpm db:generate && pnpm --filter @alma/shared build && pnpm --filter @alma/db build && pnpm --filter @alma/api build && pnpm --filter @alma/stock-api build",
    "build": "pnpm -r --if-present build",
    "start": "pnpm --filter @alma/api start",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "dev:comms": "concurrently \"pnpm --filter @alma/api dev\" \"pnpm --filter @alma/comms-web dev\"",
    "dev:comms-web": "pnpm --filter @alma/comms-web dev"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "@alma/db": "workspace:*",
    "@alma/shared": "workspace:*",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.6",
    "passkit-generator": "^3.5.7",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "stripe": "^22.1.0",
    "zod": "^3.24.3"
  }
}
