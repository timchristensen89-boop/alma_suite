# Required: production validation only runs when this is exactly "production".
NODE_ENV=production
PORT=8080
HOST=0.0.0.0

# Managed Postgres only. Do not use localhost in production.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/alma_suite?sslmode=require

# Use one long random value. Do not commit the real secret.
JWT_SECRET=replace-with-a-long-random-secret
SUITE_AUTH_SECRET=replace-with-the-same-value-on-api-and-stock-api

# Exact deployed frontend origins. Comma-separated CORS_ORIGIN also works.
CORS_ORIGIN=https://compliance.example.com,https://stock.example.com,https://staff.example.com,https://reports.example.com,https://reserve.example.com,https://marketing.example.com,https://giftcards.example.com
COMPLIANCE_WEB_URL=https://compliance.example.com
STOCK_WEB_URL=https://stock.example.com
STAFF_WEB_URL=https://staff.example.com
REPORTS_WEB_URL=https://reports.example.com
RESERVE_WEB_URL=https://reserve.example.com
MARKETING_WEB_URL=https://marketing.example.com
GIFTCARDS_WEB_URL=https://giftcards.example.com

# Optional integrations.
GOVEE_API_KEY=
GOVEE_API_BASE_URL=https://developer-api.govee.com/v1
RESEND_API_KEY=
RESEND_FROM="ALMA Staff <onboarding@example.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_REPLY_TO=
INTEGRATION_TOKEN_ENCRYPTION_KEY=
INTEGRATION_OAUTH_CONNECTIONS_ENABLED=false
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://alma-compliance.web.app/api/integrations/meta/callback
META_VERIFY_TOKEN=
META_WEBHOOK_APP_SECRET=
META_GRAPH_API_VERSION=v20.0

# Production bootstrap/import. Do not use demo seed data in production.
ALMA_ORG_NAME=Alma Group
ALMA_PRIMARY_CONTACT_NAME=Tim Christensen
ALMA_PRIMARY_CONTACT_EMAIL=tim@almagroup.com.au 
ALMA_PRIMARY_CONTACT_PHONE=0430058410   
ALMA_VENUES_JSON=[{"name":"Alma Avalon","slug":"alma-avalon"},{"name":"St Alma","slug":"st-alma"}]
PROD_ADMIN_EMAIL=
PROD_ADMIN_PASSWORD=
PROD_ADMIN_FIRST_NAME=
PROD_ADMIN_LAST_NAME=
PROD_ADMIN_ROLE=Production Admin
ALMA_CONTROL_IMPORT_FILE=tmp/alma-control-export.json
ALMA_CONTROL_TRUSTED_OPENING_BALANCES=false
