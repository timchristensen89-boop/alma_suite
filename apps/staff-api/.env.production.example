# Workforce (staff) API — production environment example
# Mirror of stock-api's env surface. Copy to your deploy target's secrets.

NODE_ENV=production
PORT=3020

# Database (shared with the suite during Phase 3; gets its own DB in Phase 4)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/alma

# Auth
STAFF_JWT_SECRET=change-me
SUITE_AUTH_SECRET=must-match-suite-handoff-secret

# Person identity comes from the suite People API
PEOPLE_API_URL=https://api.your-domain.com

# Allowed frontend origins (no localhost in production)
STAFF_CORS_ORIGIN=https://staff.your-domain.com
STAFF_WEB_URL=https://staff.your-domain.com
